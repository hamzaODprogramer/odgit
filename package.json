{
  "name": "@hamzaod/odgit",
  "version": "1.0.0",
  "description": "Beautiful retro git TUI dashboard. Keyboard-driven, zero bloat, pure terminal excellence.",
  "type": "module",
  "bin": {
    "odgit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "cli",
    "tui",
    "terminal",
    "dashboard",
    "retro",
    "dark-mode",
    "keyboard"
  ],
  "author": "hamzaODprogramer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamzaODprogramer/odgit"
  },
  "homepage": "https://github.com/hamzaODprogramer/odgit#readme",
  "bugs": {
    "url": "https://github.com/hamzaODprogramer/odgit/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "execa": "^8.0.1",
    "figlet": "^1.11.0",
    "gradient-string": "^2.0.2",
    "ink": "^4.4.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "^18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
